# Copy to .env.single-server and replace every placeholder before production.
# Production preflight forbids `$` interpolation; use direct URL-safe/base64
# secret values and URL-encode database/Redis passwords inside their URLs.

# Go API
# Production requires a full registry digest. Local development may substitute
# a mutable tag for `docker compose build`, but it cannot pass preflight.
BACKEND_IMAGE=ghcr.io/mumu-0922/neobot-mm-chat@sha256:replace-with-64-lowercase-hex
MM_CHAT_ADDR=:8080
MM_CHAT_VERSION=replace-with-release-id
DATABASE_URL=postgres://neo_chat:change-me-postgres@postgres:5432/neo_chat?sslmode=disable
DB_MAX_OPEN_CONNS=10
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=30m

# Redis temporary state. Keep REDIS_PASSWORD and REDIS_URL in sync.
REDIS_PASSWORD=change-me-redis
REDIS_URL=redis://:change-me-redis@redis:6379/0
REDIS_KEY_PREFIX=mm-chat
REDIS_RUN_CANCEL_TTL=10m
REDIS_SESSION_CACHE_TTL=5m
REDIS_RATE_LIMIT_ENABLED=true
REDIS_RATE_LIMIT_REQUESTS=120
REDIS_RATE_LIMIT_WINDOW=1m

# Auth identity/session settings. Bootstrap User ID and Display Name must remain
# stable and are used only by the one-time `admin bootstrap-identity` command.
AUTH_MODE=required
AUTH_BOOTSTRAP_USER_ID=00000000-0000-0000-0000-000000000001
AUTH_BOOTSTRAP_DISPLAY_NAME=Owner
AUTH_SESSION_TTL=168h
AUTH_RECOVERY_TTL=30m
AUTH_SMTP_ADDR=
AUTH_SMTP_USERNAME=
AUTH_SMTP_PASSWORD=
AUTH_SMTP_FROM=
AUTH_SMTP_QUEUE_SIZE=100
AUTH_SMTP_TIMEOUT=10s

# Team cursor signing and encrypted durable Invite delivery. Replace both
# change-me values with independently generated base64-encoded 32-byte keys.
# These placeholders are intentionally not usable key material. Add old
# key-id=base64 entries after commas during verify/decrypt-only rotation.
TEAM_CURSOR_ACTIVE_KEY_ID=cursor-v1
TEAM_CURSOR_KEYRING=cursor-v1=change-me-base64-32-byte-random-key
TEAM_MAIL_ACTIVE_KEY_ID=mail-v1
TEAM_MAIL_KEYRING=mail-v1=change-me-base64-32-byte-random-key
TEAM_INVITE_ACCEPT_URL_BASE=https://change-me.example/invites/accept
TEAM_MAIL_WORKER_LEASE_DURATION=30s
TEAM_MAIL_WORKER_POLL_INTERVAL=500ms
TEAM_MAIL_WORKER_BACKOFF_BASE=5s
TEAM_MAIL_WORKER_BACKOFF_MAX=15m

# OpenAI-compatible relay/provider.
PROVIDER_TYPE=openai_compatible
PROVIDER_BASE_URL=https://your-openai-compatible-relay.example/v1
PROVIDER_MODEL=gpt-5.5
PROVIDER_API_KEY=change-me-provider-key
PROVIDER_TIMEOUT=2m

# Object storage. MinIO is private; only the Go API talks to it.
STORAGE_BACKEND=minio
LOCAL_STORAGE_DIR=./data/files
S3_ENDPOINT=http://minio:9000
S3_BUCKET=neo-chat-files
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=mm-chat-files
S3_SECRET_ACCESS_KEY=change-me-minio-user-secret
S3_USE_SSL=false
S3_FORCE_PATH_STYLE=true
S3_BUCKET_AUTO_CREATE=false
MAX_UPLOAD_BYTES=52428800

# Postgres container bootstrap.
POSTGRES_DB=neo_chat
POSTGRES_USER=neo_chat
POSTGRES_PASSWORD=change-me-postgres

# MinIO root bootstrap. Do not use these root credentials from the app.
MINIO_ROOT_USER=minio-root
MINIO_ROOT_PASSWORD=change-me-minio-root-secret
