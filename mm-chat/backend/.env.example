MM_CHAT_ADDR=:8080
MM_CHAT_VERSION=dev

# Empty DATABASE_URL keeps the API in DB-disabled development mode.
# Set this before running chat CRUD or streaming endpoints.
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:15432/mm_chat?sslmode=disable
DB_MAX_OPEN_CONNS=10
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=30m

# Redis temporary state. Empty REDIS_URL disables Redis. Redis is non-authoritative:
# Postgres remains the source of truth for conversations, messages, files, and runs.
REDIS_URL=redis://:change-me@127.0.0.1:6379/0
REDIS_KEY_PREFIX=mm-chat
REDIS_RUN_CANCEL_TTL=10m
REDIS_RATE_LIMIT_ENABLED=false
REDIS_RATE_LIMIT_REQUESTS=120
REDIS_RATE_LIMIT_WINDOW=1m

# OpenAI-compatible relay/provider.
PROVIDER_TYPE=openai_compatible
PROVIDER_BASE_URL=https://your-openai-compatible-relay.example/v1
PROVIDER_MODEL=gpt-5.5
PROVIDER_API_KEY=change-me
PROVIDER_TIMEOUT=2m

# File-byte storage. Use local for dev fallback, minio for single-server MinIO,
# or s3 for an S3-compatible remote backend.
STORAGE_BACKEND=local
LOCAL_STORAGE_DIR=./data/files
S3_ENDPOINT=http://127.0.0.1:9000
S3_BUCKET=neo-chat-files
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=change-me
S3_SECRET_ACCESS_KEY=change-me
S3_USE_SSL=false
S3_FORCE_PATH_STYLE=true
S3_BUCKET_AUTO_CREATE=false
MAX_UPLOAD_BYTES=26214400
